{
  "manifest_version": 2,
  "name": "Crypte",
  "version": "1.0",
  "description": "Gestionnaire de mots de passe ultra-léger avec popup automatique.",
  "permissions": [
    "storage",
    "tabs",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "32": "icon.png"
  }
}